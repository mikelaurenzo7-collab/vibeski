# =============================================
# FIELD OF DREAMS — Production Environment
# =============================================
# Copy this to Railway environment variables
# DO NOT commit actual values to git

# --- Database (Neon PostgreSQL) ---
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-256-bit-secret-here

# --- AI Model Keys ---
# Raptor replacement → OpenAI gpt-4.1-mini (same model, no Replit lock)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude (premium 5x credit model)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Grok (xAI)
# Get from: https://console.x.ai/
XAI_API_KEY=xai-...

# --- Stripe Billing ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Stripe Price IDs ---
# Create products at: https://dashboard.stripe.com/products
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_ELITE_MONTHLY_PRICE_ID=price_...
STRIPE_ELITE_ANNUAL_PRICE_ID=price_...

# --- App ---
NODE_ENV=production
PORT=5000
# Your Railway domain or custom domain
APP_URL=https://your-app.up.railway.app
